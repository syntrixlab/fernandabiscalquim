# Frontend environment (Vite)
# Copy to client/.env.production for VPS build (or client/.env for local dev).

# API base URL used by frontend requests.
# Same domain (recommended): /api
# Separate API domain: https://api.yourdomain.com/api
VITE_API_URL=/api

# Public website URL used in admin "Visualizar site".
VITE_PUBLIC_URL=https://yourdomain.com

# CLIENT_URL no server/.env precisa apontar para a origem deste app
# (ex.: http://localhost:5173 em dev, https://crisjageneski.com.br em produção)
# para o cookie httpOnly de sessão funcionar com CORS.
